# ============================================
# Personal AI Employee - Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
# ============================================

# ===================
# SAFETY FLAGS
# ===================
# DEV_MODE prevents real external actions (emails, payments, posts)
# ALWAYS true during development!
DEV_MODE=true

# DRY_RUN logs actions without executing them
# Useful for testing workflows
DRY_RUN=true

# ===================
# LOGGING
# ===================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log format: json or text
LOG_FORMAT=text

# ===================
# GMAIL INTEGRATION
# ===================
# Create credentials at: https://console.cloud.google.com/
# Enable Gmail API and create OAuth 2.0 credentials
GMAIL_CLIENT_ID=your_client_id_here.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your_client_secret_here

# Path to OAuth credentials file (downloaded from Google Cloud Console)
GMAIL_CREDENTIALS_PATH=config/credentials.json

# Path to OAuth token (auto-created after first auth)
GMAIL_TOKEN_PATH=config/token.json

# Email to monitor (your email address)
GMAIL_USER_EMAIL=your.email@gmail.com

# Polling interval in seconds (default: 120)
GMAIL_CHECK_INTERVAL=120

# Comma-separated priority keywords (overrides gmail_config.json high-priority list)
GMAIL_KEYWORDS=urgent,invoice,payment,asap,help,deadline

# ===================
# WHATSAPP INTEGRATION
# ===================
# WhatsApp Web monitoring via Playwright browser automation
# First run: use --setup flag for QR code scan (headed mode)

# Polling interval in seconds (minimum 15 to avoid detection)
WHATSAPP_CHECK_INTERVAL=30

# Comma-separated keywords that trigger action file creation
WHATSAPP_KEYWORDS=urgent,asap,help,deadline,invoice,payment,meeting,important

# Path to Playwright persistent session data
WHATSAPP_SESSION_PATH=config/whatsapp_session

# Run browser in headless mode (set false for first-time QR scan)
WHATSAPP_HEADLESS=false

# ===================
# LINKEDIN INTEGRATION
# ===================
# LinkedIn monitoring and posting via Playwright browser automation
# First run: use --setup flag for manual login (headed mode)

# Polling interval in seconds (minimum 300 to avoid detection)
LINKEDIN_CHECK_INTERVAL=300

# Comma-separated keywords that trigger action file creation
LINKEDIN_KEYWORDS=opportunity,invoice,project,meeting,urgent,proposal,partnership,job

# Path to Playwright persistent session data
LINKEDIN_SESSION_PATH=config/linkedin_session

# Run browser in headless mode (set false for first-time login)
LINKEDIN_HEADLESS=false

# ===================
# FACEBOOK INTEGRATION
# ===================
# Facebook monitoring and posting via Playwright browser automation
# Shared session with Instagram — run facebook_watcher.py --setup first

# Polling interval in seconds (minimum 120 to avoid detection)
FACEBOOK_CHECK_INTERVAL=120

# Comma-separated keywords that trigger action file creation (empty = capture all)
FACEBOOK_KEYWORDS=urgent,invoice,meeting,proposal,partnership,opportunity

# Path to Playwright persistent session data (shared with Instagram)
FACEBOOK_SESSION_PATH=config/meta_session

# Run browser in headless mode (set false for first-time login)
FACEBOOK_HEADLESS=false

# ===================
# INSTAGRAM INTEGRATION
# ===================
# Instagram monitoring and posting via Playwright browser automation
# Shared session with Facebook — same config/meta_session directory

# Polling interval in seconds (minimum 60 to avoid detection)
INSTAGRAM_CHECK_INTERVAL=60

# Comma-separated keywords that trigger action file creation (empty = capture all)
INSTAGRAM_KEYWORDS=urgent,collab,invoice,project,partnership

# Path to Playwright persistent session data (shared with Facebook)
INSTAGRAM_SESSION_PATH=config/meta_session

# Run browser in headless mode (set false for first-time login)
INSTAGRAM_HEADLESS=false

# ===================
# TWITTER (X) INTEGRATION
# ===================
# Twitter/X monitoring and posting via Playwright browser automation
# First run: use --setup flag for manual login (headed mode)

# Polling interval in seconds (minimum 300 to avoid detection)
TWITTER_CHECK_INTERVAL=300

# Comma-separated keywords that trigger action file creation (empty = capture all)
TWITTER_KEYWORDS=urgent,help,project,collab,opportunity,mention

# Path to Playwright persistent session data (separate from Meta session)
TWITTER_SESSION_PATH=config/twitter_session

# Run browser in headless mode (set false for first-time login)
TWITTER_HEADLESS=false

# ===================
# ODOO ACCOUNTING INTEGRATION (Gold Tier)
# ===================
# Self-hosted Odoo Community Edition for invoicing, payments, and financial data
# Generate API key: Odoo Settings → Technical → API Keys → New API Key

# Odoo server URL (no trailing slash)
ODOO_URL=http://localhost:8069

# Odoo database name
ODOO_DATABASE=ai_employee

# Odoo login username (email)
ODOO_USERNAME=admin@example.com

# Odoo API key (preferred over password — generated in Odoo Settings)
ODOO_API_KEY=your-odoo-api-key-here

# Default Odoo account ID for balance queries (account.account record ID)
# Find via Odoo: Accounting → Chart of Accounts → find your main bank account ID
ODOO_MAIN_ACCOUNT_ID=1

# ===================
# RATE LIMITS
# ===================
# Override defaults from config/rate_limits.json
# RATE_LIMIT_EMAIL_PER_HOUR=10
# RATE_LIMIT_PAYMENTS_PER_HOUR=3
# RATE_LIMIT_SOCIAL_PER_DAY=5

# ===================
# PATHS
# ===================
# Vault path (relative to project root)
VAULT_PATH=./vault

# Skills path
SKILLS_PATH=./skills

# ===================
# CONTENT SCHEDULER
# ===================
# Frequency: daily | weekdays_only | custom_days
CONTENT_POST_FREQUENCY=daily

# Time to generate drafts (HH:MM, 24-hour local time)
CONTENT_POST_TIME=09:00

# IANA timezone name (e.g. Asia/Karachi, UTC, America/New_York)
CONTENT_TIMEZONE=Asia/Karachi

# Skip generating posts on Saturday and Sunday
CONTENT_SKIP_WEEKENDS=false

# ===================
# CEO BRIEFING (Gold Tier)
# ===================
# Day of week for automated briefing generation (monday | tuesday | ... | sunday)
CEO_BRIEFING_DAY=monday

# Time to generate briefing (HH:MM, 24-hour format, in local timezone)
CEO_BRIEFING_TIME=08:00

# IANA timezone name for scheduling (e.g. Asia/Karachi, UTC, America/New_York)
# Asia/Karachi = PKT = UTC+5 (Pakistan Standard Time)
CEO_BRIEFING_TIMEZONE=Asia/Karachi

# Default lookback window in days (7 = weekly, 30 = monthly, 90 = quarterly)
# Override per-run with --period N flag
CEO_BRIEFING_PERIOD_DAYS=7

# ===================
# RALPH WIGGUM LOOP
# ===================
RALPH_MAX_ITERATIONS=10      # Maximum iterations per loop (default: 10)
RALPH_ITERATION_TIMEOUT=300  # Per-iteration timeout in seconds (default: 5 min)
RALPH_TOTAL_TIMEOUT=3600     # Total session timeout in seconds (default: 60 min)

# ===================
# ANTHROPIC (for Claude API if needed)
# ===================
# ANTHROPIC_API_KEY=sk-ant-...
